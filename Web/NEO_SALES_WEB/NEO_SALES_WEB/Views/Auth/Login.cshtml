@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "_LoginLayout";
}

<div class="neo-login-wrapper d-flex align-items-center justify-content-center">
    <div class="neo-card neo-login-card p-4 p-md-5">
        <div class="text-center mb-4">
            <h1 class="neo-page-title h3 mb-1">NEO SALES</h1>
            <p class="text-muted mb-0">Inicia sesion para continuar</p>
        </div>

        <div id="neoLoginAlert" class="alert alert-danger d-none" role="alert"></div>

        <form id="neoLoginForm" novalidate data-return-url="@(ViewData["ReturnUrl"] as string ?? "/")">
            <div class="mb-3">
                <label asp-for="User" class="form-label"></label>
                <input asp-for="User" class="form-control" autocomplete="username" placeholder="Usuario" />
                <span asp-validation-for="User" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Contraseña" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-neo-primary w-100" id="neoLoginSubmit">
                <span class="neo-login-spinner spinner-border spinner-border-sm d-none me-1" aria-hidden="true"></span>
                Ingresar
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <link rel="stylesheet" href="~/css/page/auth/login.css" asp-append-version="true" />
    <script src="~/js/page/auth/login.js" asp-append-version="true"></script>
}
