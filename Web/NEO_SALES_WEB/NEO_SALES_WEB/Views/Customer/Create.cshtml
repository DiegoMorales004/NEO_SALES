@model CustomerFormViewModel
@{
    ViewData["Title"] = "Nuevo cliente";
}

<div class="mb-3">
    <a asp-controller="Customer" asp-action="Index" class="text-decoration-none">&larr; Volver a clientes</a>
</div>

<div class="neo-card neo-narrow-card p-4">
    <h1 class="neo-page-title h4 mb-4">Nuevo cliente</h1>

    <div id="neoCustomerFormAlert" class="alert alert-danger d-none" role="alert"></div>

    <form id="neoCustomerForm" novalidate>
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" maxlength="150"/>
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Nit" class="form-label"></label>
            <input asp-for="Nit" class="form-control" inputmode="numeric" maxlength="150" />
            <span asp-validation-for="Nit" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" maxlength="150"/>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-neo-primary" id="neoCustomerFormSubmit">Guardar</button>
            <a asp-controller="Customer" asp-action="Index" class="btn btn-neo-outline">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/page/customer/create.js" asp-append-version="true"></script>
}
