@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
    <h1 class="neo-page-title h3 mb-0">Clientes</h1>
    <a asp-controller="Customer" asp-action="Create" class="btn btn-neo-primary">+ Nuevo cliente</a>
</div>

<div class="neo-card p-3 mb-3">
    <div class="row g-2">
        <div class="col-12 col-md-6">
            <input type="search" id="neoCustomerSearch" class="form-control" placeholder="Buscar por nombre, correo o NIT..." />
        </div>
    </div>
</div>

<div class="neo-card p-3">
    <div id="neoCustomerLoading" class="neo-loading">Cargando clientes...</div>
    <div id="neoCustomerEmpty" class="neo-empty-state d-none">No se encontraron clientes.</div>

    <div class="table-responsive table-responsive-cards d-none" id="neoCustomerTableWrapper">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>NIT</th>
                    <th>Correo</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody id="neoCustomerTableBody"></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/page/customer/index.js" asp-append-version="true"></script>
}
