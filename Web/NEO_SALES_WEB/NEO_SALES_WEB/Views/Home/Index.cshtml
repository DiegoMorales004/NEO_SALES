@{
    ViewData["Title"] = "Inicio";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
    <div>
        <h1 class="neo-page-title h3 mb-1">Panel general</h1>
    </div>
    <a asp-controller="Sale" asp-action="Index" class="btn btn-neo-accent">Ir a Ventas</a>
</div>

<div class="row g-3 mb-4" id="neoDashboardCards">
    <div class="col-6 col-lg-3">
        <div class="neo-card kpi-card p-3 h-100">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="kpi-label">Clientes activos</span>
                <div class="kpi-icon bg-purple-soft"><i class="bi bi-people-fill"></i></div>
            </div>
            <div class="fs-2 fw-bold neo-page-title" id="neoCardCustomers">…</div>
            <a asp-controller="Customer" asp-action="Index" class="small kpi-link text-decoration-none">Ver clientes</a>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="neo-card kpi-card p-3 h-100">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="kpi-label">Productos activos</span>
                <div class="kpi-icon bg-gold-soft"><i class="bi bi-box-seam-fill"></i></div>
            </div>
            <div class="fs-2 fw-bold neo-page-title" id="neoCardProducts">…</div>
            <a asp-controller="Product" asp-action="Index" class="small kpi-link text-decoration-none">Ver productos</a>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="neo-card kpi-card p-3 h-100">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="kpi-label">Ventas pendientes</span>
                <div class="kpi-icon bg-purple-soft"><i class="bi bi-clipboard-check-fill"></i></div>
            </div>
            <div class="fs-2 fw-bold neo-page-title" id="neoCardPendingSales">…</div>
            <a asp-controller="Sale" asp-action="Index" class="small kpi-link text-decoration-none">Ver ventas</a>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="neo-card kpi-card p-3 h-100">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="kpi-label">Ventas totales</span>
                <div class="kpi-icon bg-gold-soft"><i class="bi bi-graph-up-arrow"></i></div>
            </div>
            <div class="fs-2 fw-bold neo-page-title" id="neoCardTotalSales">…</div>
            <a asp-controller="Sale" asp-action="Index" class="small kpi-link text-decoration-none">Historial</a>
        </div>
    </div>
</div>

<div class="neo-card p-4">
    <h2 class="h5 neo-page-title text-center mb-3">Acciones rápidas</h2>
    <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
        <a asp-controller="Sale" asp-action="Index" class="btn btn-neo-primary quick-action-btn">
            <span><i class="bi bi-cart-fill me-2"></i>Nueva venta</span>
            <i class="bi bi-chevron-right"></i>
        </a>
        <a asp-controller="Customer" asp-action="Create" class="btn btn-neo-outline quick-action-btn">
            <span><i class="bi bi-person-plus-fill me-2"></i>Nuevo cliente</span>
            <i class="bi bi-chevron-right"></i>
        </a>
        <a asp-controller="Product" asp-action="Create" class="btn btn-neo-outline quick-action-btn">
            <span><i class="bi bi-box-seam me-2"></i>Nuevo producto</span>
            <i class="bi bi-chevron-right"></i>
        </a>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/css/page/home/dashboard.css" asp-append-version="true" />
    <script src="~/js/page/home/dashboard.js" asp-append-version="true"></script>
}
