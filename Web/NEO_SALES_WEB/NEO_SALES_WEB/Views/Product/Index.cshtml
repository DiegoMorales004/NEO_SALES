@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
    <h1 class="neo-page-title h3 mb-0">Productos</h1>
    <a asp-controller="Product" asp-action="Create" class="btn btn-neo-primary">+ Nuevo producto</a>
</div>

<div class="neo-card p-3 mb-3">
    <div class="row g-2">
        <div class="col-12 col-md-6">
            <input type="search" id="neoProductSearch" class="form-control" placeholder="Buscar por nombre..." />
        </div>
    </div>
</div>

<div class="neo-card p-3">
    <div id="neoProductLoading" class="neo-loading">Cargando productos...</div>
    <div id="neoProductEmpty" class="neo-empty-state d-none">No se encontraron productos.</div>

    <div class="table-responsive table-responsive-cards d-none" id="neoProductTableWrapper">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody id="neoProductTableBody"></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/page/product/index.js" asp-append-version="true"></script>
}
