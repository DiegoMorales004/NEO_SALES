@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="neo-card neo-narrow-card p-4 p-md-5 text-center mx-auto">
    <h1 class="neo-page-title h3">Ocurrió un error</h1>
    <p class="text-muted">No se pudo procesar la solicitud. Intenta nuevamente en unos segundos.</p>

    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-neo-primary mt-2">Volver al inicio</a>
</div>
